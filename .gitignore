# .gitignore for MPLAB X (MPLAB X IDE v6.25) projects

# Build outputs
/dist/
/build/
**/dist/
**/build/

# Compiler/linker artifacts
*.hex
*.elf
*.map
*.o
*.d
*.dep
*.bin
*.lst

# MPLAB X / NetBeans project generated files
nbproject/private/
**/.generated_files/
**/.generated_files/**

# Autosave / backups
*.autosave
*.save
*~
*.swp

# IDE/editor
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.log

# OS files
.DS_Store
Thumbs.db

# MCC / MPLAB generated files to ignore
command_line.X/mcc-manifest*.yml
command_line.X/nbproject/private/
command_line.X/nbproject/Makefile-genesis.properties
command_line.X/nbproject/Makefile-impl.mk
command_line.X/nbproject/Makefile-local-default.mk
command_line.X/nbproject/Makefile-variables.mk
command_line.X/nbproject/Makefile-local-*.mk
